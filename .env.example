# ─── Application ─────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# ─── Security ─────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_API_KEY=change-me-to-a-32-char-random-string

# ─── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=your-redis-password

# ─── Sessions ─────────────────────────────────────────────────
SESSION_DIR=./sessions
# Maximum concurrent reconnect attempts before marking session as failed
SESSION_MAX_RECONNECT_ATTEMPTS=10
# Interval in ms for session health checks
SESSION_HEALTH_CHECK_INTERVAL=60000

# ─── Queues ───────────────────────────────────────────────────
# Max messages per minute per session (WhatsApp soft limit awareness)
QUEUE_MESSAGE_RATE_LIMIT=20
# Max concurrent jobs per session queue worker
QUEUE_CONCURRENCY=1

# ─── Webhooks ─────────────────────────────────────────────────
# Laravel webhook endpoint
WEBHOOK_URL=http://localhost:8000/webhooks/whatsapp
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEBHOOK_SECRET=change-me-to-a-32-char-random-string
# Timeout in ms for webhook HTTP requests
WEBHOOK_TIMEOUT=10000
# Max retry attempts for failed webhook deliveries
WEBHOOK_MAX_RETRIES=5

# ─── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=200

# ─── Admin (Development Only) ─────────────────────────────────
# Set to true to enable Bull Board queue UI at /admin/queues
ADMIN_ENABLED=false
ADMIN_KEY=change-me-admin-key
